      "props": {
        "backgroundColor": "default",
        "textColor": "default",
        "textAlignment": "left"
      },
      "content": [
        {
          "type": "text",
          "text": "Low-volatility regime\n",
          "styles": {
            "bold": true
          }
        },
        {
          "type": "text",
          "text": "smaller moves, calmer price action",
          "styles": {}
        }
      ],
      "children": []
    },
    {
