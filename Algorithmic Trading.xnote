      },
      "content": [
        {
          "type": "text",
          "text": "Risk-on / risk-off\n",
          "styles": {
            "bold": true
          }
        },
        {
          "type": "text",
          "text": "markets are aggressively buying risky assets vs moving into safer assets",
          "styles": {}
        }
      ],
      "children": []
    },
