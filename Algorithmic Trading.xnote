    {
      "id": "e52b2eb8-e4b7-4fae-ad1f-258408c81120",
      "type": "bulletListItem",
      "props": {
        "backgroundColor": "default",
        "textColor": "default",
        "textAlignment": "left"
      },
      "content": [
        {
          "type": "text",
          "text": "Trending up\n",
          "styles": {
            "bold": true
          }
        },
        {
          "type": "text",
          "text": "price keeps making higher highs / higher lows",
          "styles": {}
        }
      ],
      "children": []
    },
    {
      "id": "2e397529-d388-4bd0-b06d-0801180f7df3",
      "type": "bulletListItem",
      "props": {
        "backgroundColor": "default",
        "textColor": "default",
        "textAlignment": "left"
      },
      "content": [
        {
          "type": "text",
          "text": "Trending down\n",
          "styles": {
            "bold": true
          }
        },
        {
          "type": "text",
          "text": "price keeps making lower highs / lower lows",
          "styles": {}
        }
      ],
      "children": []
    },
    {
      "id": "bed28ffd-c41e-435d-bc31-db7e3bc79e45",
      "type": "bulletListItem",
      "props": {
        "backgroundColor": "default",
        "textColor": "default",
        "textAlignment": "left"
      },
      "content": [
        {
          "type": "text",
          "text": "Range-bound / sideways\n",
          "styles": {
            "bold": true
          }
        },
        {
          "type": "text",
          "text": "price moves back and forth in a band",
          "styles": {}
        }
      ],
      "children": []
    },
    {
      "id": "e4f8bf9c-e5ae-4cc1-bd0c-11424aa758bb",
      "type": "bulletListItem",
      "props": {
        "backgroundColor": "default",
        "textColor": "default",
        "textAlignment": "left"
      },
      "content": [
        {
          "type": "text",
          "text": "High-volatility regime\n",
          "styles": {
            "bold": true
          }
        },
        {
          "type": "text",
          "text": "large fast moves, wider swings, more noise",
          "styles": {}
        }
      ],
      "children": []
    },
    {
      "id": "3b9eefcf-6aa7-4c77-8768-f7971f5c8ed9",
